# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://www.optimixed.com

# ---- Supabase ----
# Project URL + anon key power public reads (RLS-restricted to published posts).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: server-only. Used by admin dashboard + ingestion pipeline. Never expose.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Admin ----
# Single-admin password gate for /admin.
ADMIN_PASSWORD=

# ---- AI pipeline ----
ANTHROPIC_API_KEY=
# Shared secret protecting /api/ingest (Vercel Cron injects it as a Bearer token).
CRON_SECRET=

# ---- Optional embeddings (cross-source semantic dedup) ----
# Leave blank to run URL/GUID/title dedup only (no semantic matching).
EMBEDDINGS_API_KEY=
# Provider: "voyage" (default) or "openai".
EMBEDDINGS_PROVIDER=voyage
# Optional model override (defaults: voyage-3.5-lite / text-embedding-3-small).
EMBEDDINGS_MODEL=
